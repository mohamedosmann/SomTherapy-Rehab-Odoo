<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for Students -->
        <record id="seq_rehab_student" model="ir.sequence">
            <field name="name">Rehab Student Sequence</field>
            <field name="code">rehab.student</field>
            <field name="prefix">STD-</field>
            <field name="padding">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequence for Staff -->
        <record id="seq_rehab_staff" model="ir.sequence">
            <field name="name">Rehab Staff Sequence</field>
            <field name="code">rehab.staff</field>
            <field name="prefix">STAFF-</field>
            <field name="padding">2</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
