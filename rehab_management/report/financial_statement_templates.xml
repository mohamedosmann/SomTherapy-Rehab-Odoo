<odoo>
    <record id="action_report_financial_statement" model="ir.actions.report">
        <field name="name">Financial Statement (PDF)</field>
        <field name="model">rehab.financial.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">rehab_management.report_financial_statement</field>
        <field name="report_file">rehab_management.report_financial_statement</field>
    </record>

    <record id="action_report_financial_statement_html" model="ir.actions.report">
        <field name="name">Financial Statement (HTML View)</field>
        <field name="model">rehab.financial.report.wizard</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">rehab_management.report_financial_statement</field>
        <field name="report_file">rehab_management.report_financial_statement</field>
    </record>

    <template id="report_financial_statement">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <style>
                    .page { font-family: 'Inter', sans-serif; color: #333; }
                    .drill-down-link { 
                        color: #1d4ed8 !important; 
                        text-decoration: underline !important; 
                        cursor: pointer !important;
                        font-weight: 500;
                        display: inline-block;
                    }
                    .drill-down-link:hover { color: #1e40af !important; background-color: #f1f5f9; border-radius: 4px; }
                    .table-reports { width: 100%; border-collapse: collapse; margin-top: 20px; }
                    .table-reports th { background: #f8fafc; padding: 12px 10px; border-bottom: 2px solid #e2e8f0; text-align: left; color: #475569; font-size: 0.875rem; }
                    .table-reports td { padding: 12px 10px; border-bottom: 1px solid #f1f5f9; color: #1e293b; font-size: 0.9375rem; }
                    .text-end { text-align: right !important; }
                    .report-header { margin-bottom: 40px; border-bottom: 2px solid #3b82f6; padding-bottom: 20px; }
                </style>
                <div class="page" id="financial_report_container">
                    <t t-set="actual_base_url" t-value="base_url or ''"/>
                    
                    <div class="text-center report-header">
                        <h1 style="font-weight: 800; color: #1e293b; margin-bottom: 8px;">
                            <t t-if="report_type == 'pl'">Profit &amp; Loss Statement</t>
                            <t t-if="report_type == 'bs'">Balance Sheet</t>
                            <t t-if="report_type == 'tb'">Trial Balance</t>
                        </h1>
                        <h3 style="color: #3b82f6; margin-bottom: 4px;"><t t-esc="res_company.name"/></h3>
                        <p style="color: #64748b; font-weight: 500;">
                            Period: <span style="color: #1e293b;"><t t-esc="date_from"/></span> to <span style="color: #1e293b;"><t t-esc="date_to"/></span>
                        </p>
                    </div>

                    <table class="table-reports">
                        <thead>
                            <tr t-if="report_type != 'tb'">
                                <th>DESCRIPTION</th>
                                <th class="text-end">BALANCE (<t t-esc="res_company.currency_id.symbol"/>)</th>
                            </tr>
                            <tr t-if="report_type == 'tb'">
                                <th>CODE</th>
                                <th>ACCOUNT</th>
                                <th class="text-end">DEBIT</th>
                                <th class="text-end">CREDIT</th>
                                <th class="text-end">NET BALANCE</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="lines" t-as="line">
                                <tr t-if="report_type != 'tb'">
                                    <td>
                                        <span class="drill-down-link js_drill_down" 
                                              t-att-data-domain="line.get('domain_str', '[]')">
                                            <t t-esc="line['name']"/>
                                        </span>
                                    </td>
                                    <td class="text-end" style="font-weight: 600;">
                                        <t t-esc="line['balance']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/>
                                    </td>
                                </tr>
                                <tr t-if="report_type == 'tb'">
                                    <td><t t-esc="line['code']"/></td>
                                    <td>
                                        <span class="drill-down-link js_drill_down" 
                                              t-att-data-domain="line.get('domain_str', '[]')">
                                            <t t-esc="line['name']"/>
                                        </span>
                                    </td>
                                    <td class="text-end"><t t-esc="line['debit']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/></td>
                                    <td class="text-end"><t t-esc="line['credit']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/></td>
                                    <td class="text-end" style="font-weight: 600;"><t t-esc="line['balance']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                    
                    <script type="text/javascript">
                        (function() {
                            var container = document.getElementById('financial_report_container');
                            if (!container) return;
                            
                            var links = container.getElementsByClassName('js_drill_down');
                            var baseUrl = '<t t-esc="actual_base_url"/>' || window.location.origin;
                            
                            for (var i = 0; i < links.length; i++) {
                                links[i].addEventListener('click', function(e) {
                                    e.preventDefault();
                                    e.stopImmediatePropagation();
                                    e.stopPropagation();
                                    
                                    var domain = this.getAttribute('data-domain');
                                    var url = baseUrl + '/web#action=account.action_account_moves_all&amp;model=account.move.line&amp;domain=' + encodeURIComponent(domain) + '&amp;context=%7B%22search_default_posted%22%3A1%7D';
                                    
                                    window.open(url, '_blank');
                                    return false;
                                }, true); // Use capture phase to intercept before Odoo
                            }
                        })();
                    </script>
                </div>
            </t>
        </t>
    </template>
</odoo>
