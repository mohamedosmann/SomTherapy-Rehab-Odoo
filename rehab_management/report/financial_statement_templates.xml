<odoo>
    <record id="action_report_financial_statement" model="ir.actions.report">
        <field name="name">Financial Statement (PDF)</field>
        <field name="model">rehab.financial.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">rehab_management.report_financial_statement</field>
        <field name="report_file">rehab_management.report_financial_statement</field>
    </record>

    <record id="action_report_financial_statement_html" model="ir.actions.report">
        <field name="name">Financial Statement (HTML View)</field>
        <field name="model">rehab.financial.report.wizard</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">rehab_management.report_financial_statement</field>
        <field name="report_file">rehab_management.report_financial_statement</field>
    </record>

    <template id="report_financial_statement">
        <t t-call="web.html_container">
            <t t-call="web.internal_layout">
                <style>
                    /* Odoo Enterprise Style Reset */
                    .o_account_reports_page {
                        font-family: "Inter", "Segoe UI", Roboto, sans-serif;
                        color: #4c4c4c;
                        font-size: 13px;
                        background-color: white !important;
                    }
                    .o_account_reports_header {
                        margin-bottom: 20px;
                        border-bottom: 1px solid #dee2e6;
                        padding-bottom: 10px;
                    }
                    .o_account_reports_header h2 {
                        color: #017e84;
                        font-weight: 700;
                        margin: 0;
                        font-size: 24px;
                    }
                    
                    /* Table Structure */
                    .o_account_report_table {
                        width: 100%;
                        border-collapse: separate;
                        border-spacing: 0;
                    }
                    .o_account_report_table thead tr th {
                        border-bottom: 2px solid #017e84;
                        color: #017e84;
                        text-transform: uppercase;
                        font-weight: 700;
                        padding: 8px 10px;
                        font-size: 11px;
                    }
                    .o_account_report_table tbody tr td {
                        padding: 6px 10px;
                        border-bottom: 1px solid #f0f0f0;
                        vertical-align: middle;
                    }
                    
                    /* Row Levels & Hierarchy */
                    .o_account_report_row_lvl0 { font-weight: 700; background-color: #f8f9fa; color: #111; border-top: 1px solid #dee2e6; }
                    .o_account_report_row_lvl1 { font-weight: 500; padding-left: 20px !important; }
                    .o_account_report_row_lvl2 { color: #666; padding-left: 40px !important; }
                    
                    .o_account_report_total { 
                        font-weight: 800 !important; 
                        background-color: #f1f8f8 !important;
                    }
                    .o_account_report_final_line {
                        border-bottom: 3px double #017e84 !important;
                        color: #017e84 !important;
                        font-size: 15px;
                    }

                    /* Alignments */
                    .number { text-align: right; font-family: 'JetBrains Mono', 'Courier New', monospace; font-weight: 600; white-space: nowrap; }
                    .text-muted { color: #8f8f8f; }

                    /* Interactivity / Drill-down */
                    .o_account_reports_web_action {
                        color: #007bff;
                        text-decoration: none;
                        cursor: pointer;
                        display: flex;
                        align-items: center;
                    }
                    .o_account_reports_web_action:hover {
                        text-decoration: underline;
                        color: #0056b3;
                    }
                    .drill_icon {
                        font-size: 10px;
                        margin-left: 5px;
                        opacity: 0.5;
                        color: #017e84;
                    }
                    
                    /* Comparison Styling */
                    .o_account_report_comparison {
                        color: #6c757d;
                        border-left: 1px solid #e9ecef;
                    }

                    /* Partner Detail Box for Ledgers */
                    .partner_header {
                        background: #34495e;
                        color: white !important;
                        padding: 8px 15px !important;
                        font-weight: bold;
                        border-radius: 4px 4px 0 0;
                        margin-top: 25px;
                    }
                    .partner_header strong { color: white; }
                </style>

                <div class="o_account_reports_page">
                    <!-- Report Title Section -->
                    <div class="o_account_reports_header">
                        <div class="row">
                            <div class="col-8">
                                <h2>
                                    <t t-if="report_type == 'pl'">Profit &amp; Loss</t>
                                    <t t-if="report_type == 'bs'">Balance Sheet</t>
                                    <t t-if="report_type == 'tb'">Trial Balance</t>
                                    <t t-if="report_type == 'customer_ledger'">Customer Ledger</t>
                                    <t t-if="report_type == 'vendor_ledger'">Vendor Ledger</t>
                                    <t t-if="report_type == 'cf'">Cash Flow</t>
                                </h2>
                                <div class="text-muted"><t t-esc="res_company.name"/></div>
                            </div>
                            <div class="col-4 text-right">
                                <div class="text-muted" style="font-size: 11px;">
                                    <strong>Period:</strong> <t t-esc="date_from"/> → <t t-esc="date_to"/><br/>
                                    <strong>Printed:</strong> <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d %H:%M')"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Main Report Content -->
                    <div class="o_account_reports_table">
                        
                        <!-- Financial Statements (P&L, BS, CF) -->
                        <t t-if="report_type in ('pl', 'bs', 'cf')">
                            <table class="o_account_report_table">
                                <thead>
                                    <tr>
                                        <th style="width: 50%;">Account / Category</th>
                                        <th class="text-right">Balance</th>
                                        <t t-if="enable_comparison"><th class="text-right o_account_report_comparison">Previous Period</th></t>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="lines" t-as="line">
                                        <tr t-attf-class="o_account_report_row_lvl{{line.get('level', 1)}} {{'o_account_report_total' if line.get('is_total') else ''}}">
                                            <td t-attf-style="padding-left: {{line.get('level', 1)*20}}px !important;">
                                                <t t-if="line.get('domain_str')">
                                                    <a t-attf-href="{{base_url}}/web#action=account.action_account_moves_all&amp;model=account.move.line&amp;domain={{line.get('domain_str')}}&amp;context={'search_default_posted':1}" 
                                                       target="_blank" class="o_account_reports_web_action o_ignore_navigation" rel="noopener">
                                                        <t t-esc="line['name']"/>
                                                        <span class="drill_icon"> ↗</span>
                                                    </a>
                                                </t>
                                                <t t-else="">
                                                    <t t-esc="line['name']"/>
                                                </t>
                                            </td>
                                            <td t-attf-class="number {{'o_account_report_final_line' if line.get('is_final') else ''}}">
                                                <t t-esc="line['balance']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/>
                                            </td>
                                            <t t-if="enable_comparison">
                                                <td class="number o_account_report_comparison">
                                                    <t t-esc="comparison_lines[line_index]['balance']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/>
                                                </td>
                                            </t>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- Ledger Style (Transaction Detail) -->
                        <t t-if="report_type in ('customer_ledger', 'vendor_ledger')">
                            <t t-foreach="lines" t-as="partner">
                                <table class="o_account_report_table" style="margin-bottom: 20px;">
                                    <thead>
                                        <tr>
                                            <th colspan="4" class="partner_header">
                                                <strong><t t-esc="partner['name']"/></strong>
                                            </th>
                                            <th colspan="2" class="partner_header text-right">
                                                <t t-esc="partner['balance']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/>
                                            </th>
                                        </tr>
                                        <tr style="background: #fdfdfd;">
                                            <th style="width: 100px;">Date</th>
                                            <th style="width: 150px;">Reference</th>
                                            <th>Label</th>
                                            <th class="text-right">Debit</th>
                                            <th class="text-right">Credit</th>
                                            <th class="text-right">Running</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="partner['transactions']" t-as="tx">
                                            <tr>
                                                <td class="text-muted"><t t-esc="tx['date']"/></td>
                                                <td><strong><t t-esc="tx['ref']"/></strong></td>
                                                <td>
                                                    <a t-attf-href="{{base_url}}/web#action=account.action_account_moves_all&amp;model=account.move.line&amp;domain={{tx.get('domain_str')}}&amp;context={'search_default_posted':1}" 
                                                       target="_blank" class="o_account_reports_web_action o_ignore_navigation" rel="noopener">
                                                        <t t-esc="tx['desc']"/>
                                                    </a>
                                                </td>
                                                <td class="number"><t t-esc="tx['debit']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/></td>
                                                <td class="number" style="color: #999;"><t t-esc="tx['credit']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/></td>
                                                <td class="number" style="color: #017e84;"><t t-esc="tx['balance']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/></td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </t>
                        </t>

                        <!-- Trial Balance Style -->
                        <t t-if="report_type == 'tb'">
                            <table class="o_account_report_table">
                                <thead>
                                    <tr>
                                        <th>Account</th>
                                        <th class="text-right">Debit</th>
                                        <th class="text-right">Credit</th>
                                        <th class="text-right">Balance</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="lines" t-as="line">
                                        <tr>
                                            <td>
                                                <span class="text-muted" style="width: 60px; display: inline-block;"><t t-esc="line['code']"/></span>
                                                <a t-attf-href="{{base_url}}/web#action=account.action_account_moves_all&amp;model=account.move.line&amp;domain={{line.get('domain_str')}}&amp;context={'search_default_posted':1}" 
                                                   target="_blank" class="o_account_reports_web_action o_ignore_navigation" rel="noopener" style="display:inline-flex;">
                                                    <strong><t t-esc="line['name']"/></strong>
                                                </a>
                                            </td>
                                            <td class="number"><t t-esc="line['debit']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/></td>
                                            <td class="number"><t t-esc="line['credit']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/></td>
                                            <td class="number"><strong><t t-esc="line['balance']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/></strong></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>
