<odoo>
    <record id="action_report_financial_statement" model="ir.actions.report">
        <field name="name">Financial Statement (PDF)</field>
        <field name="model">rehab.financial.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">rehab_management.report_financial_statement</field>
        <field name="report_file">rehab_management.report_financial_statement</field>
    </record>

    <record id="action_report_financial_statement_html" model="ir.actions.report">
        <field name="name">Financial Statement (HTML View)</field>
        <field name="model">rehab.financial.report.wizard</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">rehab_management.report_financial_statement</field>
        <field name="report_file">rehab_management.report_financial_statement</field>
    </record>

    <template id="report_financial_statement">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <style>
                    body { font-family: 'Outfit', sans-serif; background-color: #f8fafc; padding: 15px; }
                    .report-wrapper { max-width: 1200px; margin: 0 auto; background: white; border-radius: 12px; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05); padding: 40px; }
                    .report-header { border-bottom: 2px solid #e2e8f0; padding-bottom: 30px; margin-bottom: 30px; display: flex; justify-content: space-between; align-items: flex-end; }
                    .brand-side h1 { font-size: 32px; font-weight: 800; color: #1e293b; margin: 0; text-transform: uppercase; letter-spacing: -1px; }
                    .brand-side p { color: #64748b; margin: 5px 0 0; font-size: 16px; }
                    .meta-side { text-align: right; color: #64748b; font-size: 14px; }
                    
                    .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 40px; }
                    .kpi-card { background: #fdfdfd; border: 1px solid #f1f5f9; padding: 20px; border-radius: 8px; border-left: 4px solid #10b981; }
                    .kpi-val { font-size: 24px; font-weight: 700; color: #0f172a; display: block; }
                    .kpi-lbl { font-size: 12px; color: #94a3b8; text-transform: uppercase; font-weight: 600; }

                    /* Detailed Table Styling */
                    .fs-table { width: 100%; border-collapse: collapse; }
                    .fs-head { background: #f1f5f9; border-top: 2px solid #334155; }
                    .fs-head th { padding: 12px 15px; text-align: left; font-size: 12px; font-weight: 700; color: #475569; text-transform: uppercase; }
                    .fs-row { border-bottom: 1px solid #f1f5f9; transition: background 0.2s; }
                    .fs-row:hover { background: #f8fafc; }
                    .fs-row td { padding: 12px 15px; color: #334155; }
                    
                    /* Account Levels */
                    .lvl-0 { font-weight: 800 !important; font-size: 16px; border-top: 1px solid #e2e8f0; color: #0f172a !important; }
                    .lvl-1 { font-weight: 600; padding-left: 15px !important; }
                    .lvl-2 { padding-left: 40px !important; color: #64748b; font-size: 13px; }
                    .is-total { background: #fcfcfc; }
                    .final-balance { border-bottom: 4px double #10b981 !important; color: #10b981 !important; }

                    .dr-cell { text-align: right; font-weight: 600; font-family: 'Courier New', Courier, monospace; }
                    .cr-cell { text-align: right; color: #64748b; font-family: 'Courier New', Courier, monospace; }
                    .drill-btn { display: inline-block; padding: 4px 8px; font-size: 10px; background: #eff6ff; color: #2563eb; border-radius: 4px; text-decoration: none; font-weight: bold; margin-left: 10px; opacity: 0; transition: 0.2s; }
                    .fs-row:hover .drill-btn { opacity: 1; }
                    
                    .badge-posted { background: #dcfce7; color: #166534; padding: 2px 8px; border-radius: 12px; font-size: 10px; font-weight: 700; }
                </style>

                <div class="report-wrapper">
                    <div class="report-header">
                        <div class="brand-side">
                            <h1>
                                <t t-if="report_type == 'pl'">Profit &amp; Loss</t>
                                <t t-if="report_type == 'bs'">Balance Sheet</t>
                                <t t-if="report_type == 'tb'">Trial Balance</t>
                                <t t-if="report_type == 'customer_ledger'">Customer Ledger</t>
                                <t t-if="report_type == 'vendor_ledger'">Vendor Ledger</t>
                                <t t-if="report_type == 'cf'">Cash Flow</t>
                            </h1>
                            <p><t t-esc="res_company.name"/></p>
                        </div>
                        <div class="meta-side">
                            <div><strong>Period:</strong> <t t-esc="date_from"/> to <t t-esc="date_to"/></div>
                            <div><strong>Status:</strong> <span class="badge-posted">Audited / Posted</span></div>
                        </div>
                    </div>

                    <!-- P&L / BS / CF View -->
                    <t t-if="report_type in ('pl', 'bs', 'cf')">
                        <table class="fs-table">
                            <thead class="fs-head">
                                <tr>
                                    <th>Description</th>
                                    <th class="dr-cell">Current Period</th>
                                    <t t-if="enable_comparison"><th class="dr-cell">Previous Period</th></t>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="lines" t-as="line">
                                    <tr t-attf-class="fs-row {{'is-total' if line.get('is_total') else ''}} {{'lvl-' + str(line.get('level', 1))}}">
                                        <td>
                                            <t t-esc="line['name']"/>
                                            <t t-if="line.get('domain_str')">
                                                <a t-attf-href="{{base_url}}/web#action=account.action_account_moves_all&amp;model=account.move.line&amp;domain={{line.get('domain_str')}}&amp;context={'search_default_posted':1}" 
                                                   target="_blank" class="drill-btn o_ignore_navigation" rel="noopener">DRILL-DOWN</a>
                                            </t>
                                        </td>
                                        <td t-attf-class="dr-cell {{'final-balance' if line.get('is_final') else ''}}">
                                            <t t-esc="line['balance']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/>
                                        </td>
                                        <t t-if="enable_comparison">
                                            <td class="cr-cell">
                                                <t t-esc="comparison_lines[line_index]['balance']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/>
                                            </td>
                                        </t>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>

                    <!-- Ledger View (Transaction Detail) -->
                    <t t-if="report_type in ('customer_ledger', 'vendor_ledger')">
                        <t t-foreach="lines" t-as="partner">
                            <div style="margin-top: 30px; border: 1px solid #e2e8f0; border-radius: 8px; overflow: hidden;">
                                <div style="background: #f8fafc; padding: 15px; border-bottom: 2px solid #1e293b; display: flex; justify-content: space-between;">
                                    <h3 style="margin:0; font-size: 18px; font-weight: 800; color: #1e293b;"><t t-esc="partner['name']"/></h3>
                                    <span style="font-weight: bold; color: #10b981;">Balance: <t t-esc="partner['balance']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/></span>
                                </div>
                                <table class="fs-table">
                                    <thead class="fs-head" style="background: #ffffff; border-top: 0;">
                                        <tr>
                                            <th>Date</th>
                                            <th>Reference</th>
                                            <th>Label</th>
                                            <th class="dr-cell">Debit</th>
                                            <th class="dr-cell">Credit</th>
                                            <th class="dr-cell">Running</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="partner['transactions']" t-as="tx">
                                            <tr class="fs-row">
                                                <td style="font-size: 11px;"><t t-esc="tx['date']"/></td>
                                                <td style="font-size: 11px; font-weight: bold;"><t t-esc="tx['ref']"/></td>
                                                <td style="font-size: 11px; color: #64748b;"><t t-esc="tx['desc']"/></td>
                                                <td class="dr-cell" style="font-size: 11px;"><t t-esc="tx['debit']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/></td>
                                                <td class="cr-cell" style="font-size: 11px;"><t t-esc="tx['credit']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/></td>
                                                <td class="dr-cell" style="font-weight: 700; font-size: 11px;"><t t-esc="tx['balance']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/></td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>
                    </t>

                    <!-- Trial Balance View -->
                    <t t-if="report_type == 'tb'">
                        <table class="fs-table">
                            <thead class="fs-head">
                                <tr>
                                    <th>Account Name</th>
                                    <th class="dr-cell">Debit</th>
                                    <th class="dr-cell">Credit</th>
                                    <th class="dr-cell">Balance</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="lines" t-as="line">
                                    <tr class="fs-row">
                                        <td>
                                            <span style="color: #94a3b8; font-family: monospace;"><t t-esc="line['code']"/></span>
                                            <strong style="margin-left: 10px;"><t t-esc="line['name']"/></strong>
                                            <a t-attf-href="{{base_url}}/web#action=account.action_account_moves_all&amp;model=account.move.line&amp;domain={{line.get('domain_str')}}&amp;context={'search_default_posted':1}" 
                                               target="_blank" class="drill-btn o_ignore_navigation" rel="noopener">VIEW ENTRIES</a>
                                        </td>
                                        <td class="dr-cell"><t t-esc="line['debit']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/></td>
                                        <td class="cr-cell"><t t-esc="line['credit']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/></td>
                                        <td class="dr-cell"><t t-esc="line['balance']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>

                    <div style="margin-top: 60px; border-top: 1px solid #e2e8f0; padding-top: 20px; text-align: center; color: #94a3b8; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 2px;">
                        End of Statement • Internal Security Verified
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>
