<odoo>
    <record id="action_report_financial_statement_v2" model="ir.actions.report">
        <field name="name">Financial Statement (PDF)</field>
        <field name="model">rehab.financial.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">rehab_management.report_financial_statement_v2</field>
        <field name="report_file">rehab_management.report_financial_statement_v2</field>
    </record>

    <record id="action_report_financial_statement_html_v2" model="ir.actions.report">
        <field name="name">Financial Statement (HTML View)</field>
        <field name="model">rehab.financial.report.wizard</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">rehab_management.report_financial_statement_v2</field>
        <field name="report_file">rehab_management.report_financial_statement_v2</field>
    </record>

    <template id="report_financial_statement_v2">
        <t t-call="web.html_container">
            <t t-call="web.internal_layout">
                <style>
                    /* Odoo Enterprise Standard Styling */
                    .o_account_reports_page {
                        background-color: #ffffff;
                        color: #111111;
                        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans", sans-serif;
                        font-size: 13px;
                        padding: 20px 40px;
                    }
                    .o_account_reports_header {
                        display: flex;
                        justify-content: space-between;
                        align-items: flex-start;
                        margin-bottom: 30px;
                        padding-bottom: 15px;
                        border-bottom: 2px solid #dee2e6;
                    }
                    .o_account_reports_header h2 {
                        font-size: 28px;
                        font-weight: 700;
                        text-transform: uppercase;
                        color: #212529;
                        margin: 0;
                    }
                    .o_account_reports_header .company_name {
                        font-size: 16px;
                        color: #666666;
                        margin-top: 5px;
                    }
                    
                    /* Comparison/Period Badges */
                    .o_reports_badge {
                        padding: 4px 12px;
                        border-radius: 100px;
                        font-size: 11px;
                        font-weight: 700;
                        background-color: #e2f1f1;
                        color: #017e84;
                        margin-left: 10px;
                    }

                    /* Professional Table Layout */
                    .o_account_report_table {
                        width: 100%;
                        border-collapse: collapse;
                    }
                    .o_account_report_table thead th {
                        border-bottom: 2px solid #212529;
                        padding: 10px;
                        font-weight: 700;
                        color: #212529;
                        text-transform: uppercase;
                        font-size: 11px;
                    }
                    .o_account_report_table tbody tr td {
                        padding: 8px 10px;
                        border-bottom: 1px solid #e9ecef;
                        vertical-align: middle;
                    }

                    /* Indentation Levels */
                    .lvl-0 { font-weight: 700; font-size: 14px; background-color: #fcfcfc; border-top: 1px solid #dee2e6; }
                    .lvl-1 { padding-left: 20px !important; }
                    .lvl-2 { padding-left: 45px !important; color: #444; }
                    .lvl-3 { padding-left: 70px !important; font-style: italic; color: #666; font-size: 12px; }
                    
                    /* Group Toggle Caret */
                    .o_account_report_caret {
                        cursor: pointer;
                        margin-right: 8px;
                        display: inline-block;
                        width: 12px;
                        transition: transform 0.2s;
                    }
                    .row_hidden { display: none; }
                    .caret_open { transform: rotate(90deg); }
                    
                    /* Totals and Finishes */
                    .o_account_report_total { 
                        font-weight: 700 !important; 
                        color: #000000;
                    }
                    .final_total_row {
                        border-bottom: 3px double #017e84 !important;
                        font-weight: 700 !important;
                        font-size: 15px;
                        color: #017e84 !important;
                    }

                    /* Alignments and Numbers */
                    .number { 
                        text-align: right; 
                        font-variant-numeric: tabular-nums;
                        font-weight: 600;
                    }
                    
                    /* Drill-down Aesthetics */
                    .o_account_reports_web_action {
                        color: inherit;
                        text-decoration: none;
                        display: flex;
                        align-items: center;
                    }
                    .o_account_reports_web_action:hover {
                        color: #017e84;
                        text-decoration: underline;
                    }
                    .drill_arrow {
                        font-size: 9px;
                        margin-left: 6px;
                        color: #017e84;
                        opacity: 0.6;
                    }

                    /* Comparison Column */
                    .comparison_column {
                        color: #6c757d;
                        font-weight: 400;
                        background-color: #fafbfc;
                    }

                    /* Ledger Sections */
                    .ledger_partner_row {
                        background-color: #34495e;
                        color: white !important;
                        font-weight: 700;
                        padding: 10px 15px !important;
                    }
                </style>
                <script type="text/javascript">
                    (function() {
                        // Use a global click listener for dynamic content
                        document.addEventListener('click', function(e) {
                            // 1. Handle Expand/Collapse
                            const caret = e.target.closest('.o_account_report_caret');
                            if (caret) {
                                e.preventDefault();
                                e.stopPropagation();
                                const row = caret.closest('tr');
                                const groupName = row.getAttribute('data-group-name');
                                caret.classList.toggle('caret_open');
                                document.querySelectorAll('tr[data-parent-group="' + groupName + '"]').forEach(function(subRow) {
                                    subRow.classList.toggle('row_hidden');
                                });
                                return;
                            }

                            // 2. Handle Drill-down Click
                            const link = e.target.closest('.o_account_reports_web_action');
                            if (link) {
                                e.preventDefault();
                                e.stopPropagation();
                                const domainStr = link.getAttribute('data-domain');
                                if (!domainStr) return;
                                
                                try {
                                    const domain = JSON.parse(domainStr);
                                    const action = {
                                        type: 'ir.actions.act_window',
                                        name: link.innerText.trim() || 'Drill-down',
                                        res_model: link.getAttribute('data-res-model') || 'account.move.line',
                                        domain: domain,
                                        views: [[false, 'list'], [false, 'form']],
                                        view_mode: 'list,form',
                                        target: 'current',
                                        context: { 'active_test': false }
                                    };

                                    // Reach the Odoo action service in the parent window
                                    if (window.parent &amp;&amp; window.parent.odoo &amp;&amp; window.parent.odoo.__WOWL_DEBUG__ &amp;&amp; window.parent.odoo.__WOWL_DEBUG__.root) {
                                        // Modern Odoo (16/17+)
                                        const actionService = window.parent.odoo.__WOWL_DEBUG__.root.env.services.action;
                                        actionService.doAction(action);
                                    } else if (window.parent &amp;&amp; window.parent.odoo &amp;&amp; window.parent.odoo.actionService) {
                                        // Variant
                                        window.parent.odoo.actionService.doAction(action);
                                    } else {
                                        console.error("Odoo Action Service not found in parent window.");
                                        // Fallback: postMessage
                                        window.parent.postMessage(action, "*");
                                    }
                                } catch (err) {
                                    console.error("Drill-down error:", err);
                                }
                            }
                        });
                    })();
                </script>

                <div class="o_account_reports_page">
                    <!-- Report Header: Clean & Standard -->
                    <div class="o_account_reports_header">
                        <div>
                            <h2>
                                <t t-if="report_type == 'pl'">Profit and Loss</t>
                                <t t-if="report_type == 'bs'">Balance Sheet</t>
                                <t t-if="report_type == 'tb'">Trial Balance</t>
                                <t t-if="report_type == 'customer_ledger'">Customer Ledger</t>
                                <t t-if="report_type == 'vendor_ledger'">Vendor Ledger</t>
                            </h2>
                            <div class="company_name"><t t-esc="res_company.name"/></div>
                        </div>
                        <div class="text-right">
                            <span class="o_reports_badge">
                                <t t-esc="date_from"/> → <t t-esc="date_to"/>
                            </span>
                            <div style="margin-top: 10px; font-size: 11px; color: #999;">
                                Printed: <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d %H:%M')"/>
                            </div>
                        </div>
                    </div>

                    <!-- Financial Statement Table -->
                    <t t-if="report_type in ('pl', 'bs', 'cf')">
                        <table class="o_account_report_table">
                            <thead>
                                <tr>
                                    <th style="width: 60%;">Description</th>
                                    <th class="text-right">Balance</th>
                                    <t t-if="enable_comparison"><th class="text-right comparison_column">Previous</th></t>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="lines" t-as="line">
                                    <tr t-attf-class="lvl-{{line.get('level', 1)}} {{'o_account_report_total' if line.get('is_total') else ''}} {{'o_js_account_report_group' if line.get('is_group') else ''}} {{'row_hidden' if line.get('parent_group') else ''}}" 
                                        t-att-data-group-name="line['name']" 
                                        t-att-data-parent-group="line.get('parent_group')">
                                        <td class="account_name_cell">
                                            <t t-if="line.get('is_group')">
                                                <span class="o_account_report_caret">▼</span>
                                            </t>
                                            <t t-if="line.get('drill_url')">
                                                <a t-att-href="line['drill_url']" target="_parent" class="o_account_reports_web_action o_ignore_navigation">
                                                    <t t-esc="line['name']"/><span class="drill_arrow">↗</span>
                                                </a>
                                            </t>
                                            <t t-else="">
                                                <t t-esc="line['name']"/>
                                            </t>
                                        </td>
                                        <td t-attf-class="number {{'final_total_row' if line.get('is_final') else ''}}">
                                            <t t-esc="line['balance']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/>
                                        </td>
                                        <t t-if="enable_comparison">
                                            <td class="number comparison_column">
                                                <t t-esc="comparison_lines[line_index]['balance']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/>
                                            </td>
                                        </t>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>

                    <!-- Ledger Table -->
                    <t t-if="report_type in ('customer_ledger', 'vendor_ledger')">
                        <t t-foreach="lines" t-as="partner">
                            <table class="o_account_report_table" style="margin-top: 25px;">
                                <thead>
                                    <tr class="ledger_partner_row">
                                        <th colspan="4" style="color: white;"><t t-esc="partner['name']"/></th>
                                        <th colspan="2" class="text-right" style="color: white;">
                                            <t t-esc="partner['balance']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/>
                                        </th>
                                    </tr>
                                    <tr style="background: #f8f9fa;">
                                        <th style="width: 12%;">Date</th>
                                        <th style="width: 18%;">Ref</th>
                                        <th>Label</th>
                                        <th class="text-right" style="width: 15%;">Debit</th>
                                        <th class="text-right" style="width: 15%;">Credit</th>
                                        <th class="text-right" style="width: 15%;">Cumul.</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="partner['transactions']" t-as="tx">
                                        <tr>
                                            <td style="color: #666;"><t t-esc="tx['date']"/></td>
                                            <td><strong><t t-esc="tx['ref']"/></strong></td>
                                            <td>
                                                <a href="#" class="o_account_reports_web_action o_ignore_navigation" t-att-data-domain="tx['domain_str']" t-att-data-res-model="'account.move.line'">
                                                    <t t-esc="tx['desc']"/>
                                                </a>
                                            </td>
                                            <td class="number"><t t-esc="tx['debit']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/></td>
                                            <td class="number" style="color: #bbb;"><t t-esc="tx['credit']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/></td>
                                            <td class="number" style="color: #017e84;"><t t-esc="tx['balance']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>
                    </t>

                    <!-- Trial Balance Table -->
                    <t t-if="report_type == 'tb'">
                        <table class="o_account_report_table">
                            <thead>
                                <tr>
                                    <th>Account</th>
                                    <th class="text-right">Debit</th>
                                    <th class="text-right">Credit</th>
                                    <th class="text-right">Balance</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="lines" t-as="line">
                                    <tr>
                                        <td>
                                            <span style="color: #999; width: 70px; display: inline-block;"><t t-esc="line['code']"/></span>
                                            <a href="#" class="o_account_reports_web_action o_ignore_navigation" t-att-data-domain="line['domain_str']" t-att-data-res-model="'account.move.line'" style="display:inline-flex;">
                                                <strong><t t-esc="line['name']"/></strong>
                                            </a>
                                        </td>
                                        <td class="number"><t t-esc="line['debit']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/></td>
                                        <td class="number"><t t-esc="line['credit']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/></td>
                                        <td class="number"><strong><t t-esc="line['balance']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/></strong></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                </div>
            </t>
        </t>
    </template>
</odoo>
