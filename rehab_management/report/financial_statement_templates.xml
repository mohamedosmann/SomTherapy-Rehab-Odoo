<odoo>
    <record id="action_report_financial_statement" model="ir.actions.report">
        <field name="name">Financial Statement (PDF)</field>
        <field name="model">rehab.financial.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">rehab_management.report_financial_statement</field>
        <field name="report_file">rehab_management.report_financial_statement</field>
    </record>

    <record id="action_report_financial_statement_html" model="ir.actions.report">
        <field name="name">Financial Statement (HTML View)</field>
        <field name="model">rehab.financial.report.wizard</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">rehab_management.report_financial_statement</field>
        <field name="report_file">rehab_management.report_financial_statement</field>
    </record>

    <template id="report_financial_statement">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <style>
                    body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f3f4f6; padding: 20px; }
                    .report-card { background: white; border-radius: 8px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); padding: 30px; max-width: 1000px; margin: 0 auto; }
                    .report-header { text-align: center; border-bottom: 3px solid #10b981; padding-bottom: 20px; margin-bottom: 30px; }
                    .report-title { color: #064e3b; font-size: 28px; font-weight: bold; margin: 0; }
                    .report-subtitle { color: #059669; font-size: 18px; margin: 5px 0; }
                    .data-row { display: flex; justify-content: space-between; padding: 12px 15px; border-bottom: 1px solid #e5e7eb; align-items: center; }
                    .data-row:hover { background-color: #f9fafb; }
                    .label-cell { flex: 2; font-weight: 500; color: #374151; }
                    .value-cell { flex: 1; text-align: right; font-weight: 600; color: #111827; }
                    .drill-link { color: #2563eb !important; text-decoration: none !important; }
                    .drill-link:hover { text-decoration: underline !important; color: #1d4ed8 !important; }
                    .header-row { display: flex; justify-content: space-between; padding: 10px 15px; background: #f8fafc; border-bottom: 2px solid #cbd5e1; font-weight: bold; color: #475569; text-transform: uppercase; font-size: 12px; }
                </style>
                <div class="report-card">
                    <div class="report-header">
                        <p style="color:red; font-weight:bold;">SYSTEM UPDATE VERIFIED v1.6</p>
                        <h1 class="report-title">
                            <t t-if="report_type == 'pl'">Profit &amp; Loss Statement</t>
                            <t t-if="report_type == 'bs'">Balance Sheet</t>
                            <t t-if="report_type == 'tb'">Trial Balance</t>
                        </h1>
                        <h2 class="report-subtitle"><t t-esc="res_company.name"/></h2>
                        <p style="color: #6b7280;">Period: <t t-esc="date_from"/> to <t t-esc="date_to"/></p>
                    </div>

                    <div class="header-row">
                        <span>Description</span>
                        <span>Balance</span>
                    </div>

                    <!-- DIV BASED LAYOUT TO AVOID ODOO TABLE ENRICHMENT CRASH -->
                    <div class="report-body">
                        <t t-foreach="lines" t-as="line">
                            <div class="data-row">
                                <div class="label-cell">
                                    <a t-att-href="'%s/web#action=account.action_account_moves_all&amp;model=account.move.line&amp;domain=%s&amp;context={\"search_default_posted\":1}' % (base_url or '', line.get('domain_str', '[]'))" 
                                       target="_blank" class="drill-link o_ignore_navigation" rel="noopener">
                                        <t t-esc="line['name']"/>
                                    </a>
                                </div>
                                <div class="value-cell">
                                    <t t-esc="line['balance']" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/>
                                </div>
                            </div>
                        </t>
                    </div>

                    <div style="margin-top: 40px; text-align: center; color: #9ca3af; font-size: 11px;">
                        Generated on <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d %H:%M:%S')"/>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>
