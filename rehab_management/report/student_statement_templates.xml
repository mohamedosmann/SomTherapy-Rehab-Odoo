<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_student_statement" model="ir.actions.report">
        <field name="name">Statement of Account</field>
        <field name="model">rehab.student</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">rehab_management.report_student_statement</field>
        <field name="report_file">rehab_management.report_student_statement</field>
        <field name="print_report_name">'Statement - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_rehab_student"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_student_statement">
        <t t-call="web.html_container">
            <t t-foreach="doc_data" t-as="d">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="row">
                            <div class="col-6">
                                <h2>Statement of Account</h2>
                                <h4 t-out="d['student'].name"/>
                                <p>Student ID: <span t-out="d['student'].student_id"/></p>
                            </div>
                            <div class="col-6 text-end">
                                <p><strong>Date Generated:</strong> <span t-out="context_today().strftime('%Y-%m-%d')"/></p>
                                <p><strong>Current Balance:</strong> 
                                    <span t-out="d['final_balance']" t-options='{"widget": "monetary", "display_currency": company.currency_id}'/>
                                </p>
                            </div>
                        </div>
                        <br/>
                        <table class="table table-sm o_main_table">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Reference</th>
                                    <th>Description</th>
                                    <th class="text-end">Debit (Fee)</th>
                                    <th class="text-end">Credit (Paid)</th>
                                    <th class="text-end">Balance</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="d['lines']" t-as="line">
                                    <tr>
                                        <td><span t-out="line['date']"/></td>
                                        <td><span t-out="line['ref']"/></td>
                                        <td><span t-out="line['label']"/></td>
                                        <td class="text-end">
                                            <span t-if="line['debit'] > 0" t-out="line['debit']" t-options='{"widget": "monetary", "display_currency": company.currency_id}'/>
                                        </td>
                                        <td class="text-end">
                                            <span t-if="line['credit'] > 0" t-out="line['credit']" t-options='{"widget": "monetary", "display_currency": company.currency_id}'/>
                                        </td>
                                        <td class="text-end">
                                            <span t-out="line['balance']" t-options='{"widget": "monetary", "display_currency": company.currency_id}'/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                        
                        <div class="row justify-content-end">
                            <div class="col-4">
                                <table class="table table-sm">
                                    <tr class="border-black o_total">
                                        <td><strong>TOTAL DUE</strong></td>
                                        <td class="text-end">
                                            <strong>
                                                <span t-out="d['final_balance']" t-options='{"widget": "monetary", "display_currency": company.currency_id}'/>
                                            </strong>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
