<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_student_statement" model="ir.actions.report">
        <field name="name">Statement of Account</field>
        <field name="model">rehab.student</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">rehab_management.report_student_statement</field>
        <field name="report_file">rehab_management.report_student_statement</field>
        <field name="print_report_name">'Statement - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_rehab_student"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_student_statement">
        <t t-call="web.html_container">
            <t t-foreach="doc_data" t-as="d">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Inter', sans-serif; color: #2c3e50;">
                        <!-- Report Header -->
                        <div class="row mb-4 border-bottom pb-3">
                            <div class="col-6">
                                <h2 style="color: #1f77b4; font-weight: bold;">STATEMENT OF ACCOUNT</h2>
                                <h4 class="mt-3"><t t-out="d['student'].name"/></h4>
                                <div class="text-muted" style="font-size: 0.9em;">
                                    <p class="mb-0"><strong>Student ID:</strong> <span t-out="d['student'].student_id"/></p>
                                    <p class="mb-0"><strong>Type:</strong> <span t-out="d['student'].type_id.name"/></p>
                                    <p t-if="d['student'].room_id" class="mb-0"><strong>Room:</strong> <span t-out="d['student'].room_id.name"/></p>
                                </div>
                            </div>
                            <div class="col-6 text-end">
                                <div t-if="company.logo" class="mb-2">
                                    <img t-att-src="image_data_uri(company.logo)" style="max-height: 70px;" alt="Logo"/>
                                </div>
                                <p class="mb-0 text-muted">Generated: <span t-out="context_today().strftime('%B %d, %Y')"/></p>
                            </div>
                        </div>

                        <!-- Summary Cards -->
                        <div class="row mb-5">
                            <div class="col-4">
                                <div class="card text-center p-3 border-0" style="background: #fdf2f2;">
                                    <div class="text-uppercase text-muted" style="font-size: 0.75em; font-weight: bold;">Total Fees &amp; Charges</div>
                                    <div style="font-size: 1.5em; font-weight: bold; color: #c0392b;">
                                        <span t-out="d['total_debit']" t-options='{"widget": "monetary", "display_currency": company.currency_id}'/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="card text-center p-3 border-0" style="background: #f2fdf6;">
                                    <div class="text-uppercase text-muted" style="font-size: 0.75em; font-weight: bold;">Total Payments Received</div>
                                    <div style="font-size: 1.5em; font-weight: bold; color: #27ae60;">
                                        <span t-out="d['total_credit']" t-options='{"widget": "monetary", "display_currency": company.currency_id}'/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="card text-center p-3 border-0" style="background: #f2f7fd;">
                                    <div class="text-uppercase text-muted" style="font-size: 0.75em; font-weight: bold;">Net Balance Due</div>
                                    <div style="font-size: 1.5em; font-weight: bold; color: #2980b9;">
                                        <span t-out="d['final_balance']" t-options='{"widget": "monetary", "display_currency": company.currency_id}'/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Main Ledger -->
                        <h5 class="mb-3" style="color: #34495e;">Ledger Details</h5>
                        <table class="table table-hover table-sm">
                            <thead style="background-color: #f8f9fa;">
                                <tr>
                                    <th class="py-2 px-3 border-0">DATE</th>
                                    <th class="py-2 border-0">DESCRIPTION &amp; REFERENCE</th>
                                    <th class="py-2 text-end border-0">CHARGES (+)</th>
                                    <th class="py-2 text-end border-0">PAYMENTS (-)</th>
                                    <th class="py-2 text-end border-0" style="background: #f2f7fd;">RUNNING BALANCE</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="d['lines']" t-as="line">
                                    <tr style="border-bottom: 1px solid #eee;">
                                        <td class="px-3"><span t-out="line['date'].strftime('%Y-%m-%d')"/></td>
                                        <td>
                                            <div style="font-weight: 500;"><t t-esc="line['label']"/></div>
                                            <div class="text-muted small"><t t-esc="line['ref']"/></div>
                                        </td>
                                        <td class="text-end">
                                            <span t-if="line['debit'] > 0" t-out="line['debit']" t-options='{"widget": "monetary", "display_currency": company.currency_id}'/>
                                        </td>
                                        <td class="text-end">
                                            <span t-if="line['credit'] > 0" t-out="line['credit']" t-options='{"widget": "monetary", "display_currency": company.currency_id}'/>
                                        </td>
                                        <td class="text-end" style="background: #fbfcfe;">
                                            <span t-out="line['balance']" t-options='{"widget": "monetary", "display_currency": company.currency_id}'/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                        
                        <!-- Settlement Summary (Bottom Side) -->
                        <div class="row justify-content-end mt-5">
                            <div class="col-5">
                                <div class="p-3 shadow-sm rounded border" style="background: #1f77b4; color: whitesmoke;">
                                    <div class="row">
                                        <div class="col-7">TOTAL OUTSTANDING DUE</div>
                                        <div class="col-5 text-end h4 mb-0">
                                            <span t-out="d['final_balance']" t-options='{"widget": "monetary", "display_currency": company.currency_id}'/>
                                        </div>
                                    </div>
                                </div>
                                <div class="text-end mt-2 small text-muted">
                                    <p>Please settle the account balance promptly to avoid program interruption. Thank you.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
