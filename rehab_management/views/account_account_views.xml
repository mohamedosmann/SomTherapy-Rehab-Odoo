<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_form_rehab_inherit" model="ir.ui.view">
        <field name="name">account.account.form.rehab.inherit</field>
        <field name="model">account.account</field>
        <field name="inherit_id" ref="account.view_account_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group" position="after">
                <group string="IFRS Reporting">
                    <field name="ifrs_category"/>
                    <field name="ifrs_note" placeholder="Notes for Disclosure in Financial Statements..."/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
