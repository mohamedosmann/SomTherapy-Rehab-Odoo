<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_journal_form_inherited_rehab" model="ir.ui.view">
        <field name="name">account.journal.form.inherited.rehab</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">
            <!-- Add clarity to account fields -->
            <xpath expr="//field[@name='default_account_id']" position="attributes">
                <attribute name="string">Bank Account (Direct Posting)</attribute>
            </xpath>

            <!-- Add Register Payment buttons inside the sheet, at the top if possible -->
            <xpath expr="//sheet" position="inside">
                <div class="o_horizontal_separator" invisible="type not in ('bank', 'cash')">Direct Payments</div>
                <div class="oe_button_box" name="button_box_rehab" style="position: relative; float: none; display: block; margin-bottom: 20px;" invisible="type not in ('bank', 'cash')">
                    <button name="%(account.action_account_payments)d" string="Register Incoming Payment" type="action" class="btn-primary" context="{'default_payment_type': 'inbound', 'default_journal_id': active_id}"/>
                    <button name="%(account.action_account_payments_payable)d" string="Register Outgoing Payment" type="action" class="btn-secondary" context="{'default_payment_type': 'outbound', 'default_journal_id': active_id}"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
