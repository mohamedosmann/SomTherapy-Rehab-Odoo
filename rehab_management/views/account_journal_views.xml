<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_journal_form_inherited_rehab" model="ir.ui.view">
        <field name="name">account.journal.form.inherited.rehab</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='default_account_id']" position="attributes">
                <attribute name="string">Bank Account (Direct Posting)</attribute>
            </xpath>
        </field>
    </record>
</odoo>
