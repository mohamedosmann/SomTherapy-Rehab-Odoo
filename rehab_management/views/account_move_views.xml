<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_rehab_inherit" model="ir.ui.view">
        <field name="name">account.move.form.rehab.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='account_id']" position="after">
                <field name="is_deferred" optional="show"/>
                <field name="deferral_duration" invisible="not is_deferred" optional="show"/>
                <field name="deferral_start_date" invisible="not is_deferred" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
