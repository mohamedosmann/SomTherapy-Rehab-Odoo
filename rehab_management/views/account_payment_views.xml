<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_payment_form_inherit_advance" model="ir.ui.view">
        <field name="name">account.payment.form.inherit.advance</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_method_line_id']" position="after">
                <field name="is_advance" invisible="state != 'draft'"/>
                <field name="advance_account_id" invisible="not is_advance" required="is_advance" readonly="state != 'draft'"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <div class="alert alert-info" role="alert" invisible="not is_advance">
                    This is an <strong>Advance Payment</strong>. It will be recorded to the liability/prepayment account.
                </div>
            </xpath>
        </field>
    </record>

    <!-- Context for Register Advance Payment Action -->
    <record id="action_account_payments_advance" model="ir.actions.act_window">
        <field name="name">Register Advance Payment</field>
        <field name="res_model">account.payment</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_is_advance': True}</field>
    </record>
</odoo>
