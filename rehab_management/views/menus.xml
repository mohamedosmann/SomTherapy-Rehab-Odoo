<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <!-- Root Menu -->
        <menuitem id="rehab_root_menu" name="Rehab &amp; Finance" sequence="10"/>

        <!-- Top Categories (Simplified Order) -->
        <menuitem id="rehab_students_menu_cat" name="1. Student Admitting" parent="rehab_root_menu" sequence="10"/>
        <menuitem id="rehab_financials_menu_cat" name="2. Monthly Billing" parent="rehab_root_menu" sequence="20"/>
        <menuitem id="rehab_finance_dashboard_cat" name="3. Money Tracking" parent="rehab_root_menu" sequence="30"/>
        
        <menuitem id="rehab_discipline_menu_cat" name="Discipline" parent="rehab_root_menu" sequence="40"/>
        <menuitem id="rehab_dormitory_menu_cat" name="Dormitory" parent="rehab_root_menu" sequence="50"/>
        <menuitem id="rehab_logistics_menu_cat" name="Logistics &amp; Purchase" parent="rehab_root_menu" sequence="60"/>
        <menuitem id="rehab_configuration_cat" name="Settings" parent="rehab_root_menu" sequence="100"/>

        <!-- Actions -->
        <record id="action_rehab_student" model="ir.actions.act_window">
            <field name="name">Students</field>
            <field name="res_model">rehab.student</field>
            <field name="view_mode">list,form,kanban</field>
        </record>

        <record id="action_rehab_discipline_case" model="ir.actions.act_window">
            <field name="name">Discipline Cases</field>
            <field name="res_model">rehab.discipline.case</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_rehab_room" model="ir.actions.act_window">
            <field name="name">Rooms</field>
            <field name="res_model">rehab.room</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_rehab_teacher" model="ir.actions.act_window">
            <field name="name">Teachers</field>
            <field name="res_model">rehab.teacher</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_rehab_class" model="ir.actions.act_window">
            <field name="name">Classes</field>
            <field name="res_model">rehab.class</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_rehab_student_type" model="ir.actions.act_window">
            <field name="name">Student Types</field>
            <field name="res_model">rehab.student.type</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Submenus: Students -->
        <menuitem id="menu_rehab_student" name="Students" parent="rehab_students_menu_cat" action="action_rehab_student" sequence="10"/>
        
        <!-- Submenus: Discipline -->
        <menuitem id="menu_rehab_discipline_case" name="Discipline Cases" parent="rehab_discipline_menu_cat" action="action_rehab_discipline_case" sequence="10"/>
        
        <!-- Submenus: Dormitory -->
        <menuitem id="menu_rehab_room" name="Rooms" parent="rehab_dormitory_menu_cat" action="action_rehab_room" sequence="10"/>
        <menuitem id="menu_rehab_teacher" name="Teachers" parent="rehab_dormitory_menu_cat" action="action_rehab_teacher" sequence="20"/>
        <menuitem id="menu_rehab_class" name="Classes" parent="rehab_dormitory_menu_cat" action="action_rehab_class" sequence="30"/>

        <!-- Submenus: Logistics (Native Odoo) -->
        <menuitem id="menu_rehab_inventory" name="Inventory Overview" parent="rehab_logistics_menu_cat" action="stock.stock_picking_type_action" sequence="10"/>
        <menuitem id="menu_rehab_stock_moves" name="Stock Moves" parent="rehab_logistics_menu_cat" action="stock.stock_move_line_action" sequence="20"/>
        <menuitem id="menu_rehab_stock_levels" name="Current Stock Levels" parent="rehab_logistics_menu_cat" action="stock.location_open_quants" sequence="30"/>
        <menuitem id="menu_rehab_purchase_rfq" name="Requests for Quotation" parent="rehab_logistics_menu_cat" action="purchase.purchase_rfq" sequence="40"/>
        <menuitem id="menu_rehab_purchase_orders" name="Purchase Orders" parent="rehab_logistics_menu_cat" action="purchase.purchase_form_action" sequence="50"/>

        <!-- Submenus: Financials (Simplified) -->
        <menuitem id="menu_rehab_billing" name="Generate Monthly Billing" parent="rehab_financials_menu_cat" action="action_rehab_billing_wizard" sequence="5"/>
        
        <!-- Money Tracking Dashboard Items -->
        <menuitem id="menu_rehab_money_in" name="Money IN (Invoices)" parent="rehab_finance_dashboard_cat" action="account.action_move_out_invoice_type" sequence="10"/>
        <menuitem id="menu_rehab_money_out" name="Money OUT (Teacher Salaries)" parent="rehab_finance_dashboard_cat" action="account.action_move_in_invoice_type" sequence="20"/>
        <menuitem id="menu_rehab_payments" name="Payments Received" parent="rehab_finance_dashboard_cat" action="account.action_account_payments" sequence="30"/>
        
        <menuitem id="menu_rehab_finance_reports_cat" name="Finance Reports (IFRS)" parent="rehab_finance_dashboard_cat" sequence="100"/>
        
        <menuitem id="menu_rehab_report_pl" name="Profit &amp; Loss" parent="menu_rehab_finance_reports_cat" 
                  action="action_rehab_financial_report_wizard" sequence="10" context="{'default_report_type': 'pl'}"/>
        
        <menuitem id="menu_rehab_report_bs" name="Balance Sheet" parent="menu_rehab_finance_reports_cat" 
                  action="action_rehab_financial_report_wizard" sequence="20" context="{'default_report_type': 'bs'}"/>
        
        <menuitem id="menu_rehab_report_tb" name="Trial Balance" parent="menu_rehab_finance_reports_cat" 
                  action="action_rehab_financial_report_wizard" sequence="30" context="{'default_report_type': 'tb'}"/>

        <menuitem id="menu_rehab_ledger" name="Complete Ledger (Journal Items)" parent="menu_rehab_finance_reports_cat" action="account.action_account_moves_all" sequence="40"/>

        <!-- Accounting Configuration & Reports -->
        <menuitem id="menu_rehab_accounting_section" name="Accounting Settings" parent="rehab_configuration_cat" sequence="20"/>
        <menuitem id="menu_rehab_journals" name="Journals" parent="menu_rehab_accounting_section" action="account.action_account_journal_form" sequence="10"/>
        <menuitem id="menu_rehab_chart_of_accounts" name="Chart of Accounts" parent="menu_rehab_accounting_section" action="account.action_account_form" sequence="20"/>

        <menuitem id="menu_rehab_student_type" name="Student Types" parent="rehab_configuration_cat" action="action_rehab_student_type" sequence="5"/>
</odoo>
