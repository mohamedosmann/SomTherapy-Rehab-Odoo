<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rehab_root_menu" model="ir.ui.menu">
        <field name="name">Rehab &amp; Finance</field>
        <field name="sequence">10</field>
    </record>

    <record id="rehab_students_menu_cat" model="ir.ui.menu">
        <field name="name">1. Student Admitting</field>
        <field name="parent_id" ref="rehab_root_menu"/>
        <field name="sequence">10</field>
    </record>

    <record id="rehab_financials_menu_cat" model="ir.ui.menu">
        <field name="name">2. Monthly Billing</field>
        <field name="parent_id" ref="rehab_root_menu"/>
        <field name="sequence">20</field>
    </record>

    <record id="rehab_finance_dashboard_cat" model="ir.ui.menu">
        <field name="name">3. Money Tracking</field>
        <field name="parent_id" ref="rehab_root_menu"/>
        <field name="sequence">30</field>
    </record>

    <record id="rehab_discipline_menu_cat" model="ir.ui.menu">
        <field name="name">Discipline</field>
        <field name="parent_id" ref="rehab_root_menu"/>
        <field name="sequence">40</field>
    </record>

    <record id="rehab_dormitory_menu_cat" model="ir.ui.menu">
        <field name="name">Dormitory</field>
        <field name="parent_id" ref="rehab_root_menu"/>
        <field name="sequence">50</field>
    </record>

    <record id="rehab_logistics_menu_cat" model="ir.ui.menu">
        <field name="name">Logistics &amp; Purchase</field>
        <field name="parent_id" ref="rehab_root_menu"/>
        <field name="sequence">60</field>
    </record>

    <record id="rehab_configuration_cat" model="ir.ui.menu">
        <field name="name">Settings</field>
        <field name="parent_id" ref="rehab_root_menu"/>
        <field name="sequence">100</field>
    </record>

    <!-- Actions -->
    <record id="action_rehab_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">rehab.student</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

    <record id="action_rehab_discipline_case" model="ir.actions.act_window">
        <field name="name">Discipline Cases</field>
        <field name="res_model">rehab.discipline.case</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_rehab_room" model="ir.actions.act_window">
        <field name="name">Rooms</field>
        <field name="res_model">rehab.room</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_rehab_teacher" model="ir.actions.act_window">
        <field name="name">Teachers</field>
        <field name="res_model">rehab.teacher</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_rehab_class" model="ir.actions.act_window">
        <field name="name">Classes</field>
        <field name="res_model">rehab.class</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_rehab_student_type" model="ir.actions.act_window">
        <field name="name">Student Types</field>
        <field name="res_model">rehab.student.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Report Actions with Specific Contexts -->
    <record id="action_rehab_report_pl" model="ir.actions.act_window">
        <field name="name">Profit &amp; Loss</field>
        <field name="res_model">rehab.financial.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_report_type': 'pl'}</field>
    </record>

    <record id="action_rehab_report_bs" model="ir.actions.act_window">
        <field name="name">Balance Sheet</field>
        <field name="res_model">rehab.financial.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_report_type': 'bs'}</field>
    </record>

    <record id="action_rehab_report_tb" model="ir.actions.act_window">
        <field name="name">Trial Balance</field>
        <field name="res_model">rehab.financial.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_report_type': 'tb'}</field>
    </record>

    <!-- Submenus -->
    <record id="menu_rehab_student" model="ir.ui.menu">
        <field name="name">Students</field>
        <field name="parent_id" ref="rehab_students_menu_cat"/>
        <field name="action" ref="action_rehab_student"/>
        <field name="sequence">10</field>
    </record>

    <record id="menu_rehab_discipline_case" model="ir.ui.menu">
        <field name="name">Discipline Cases</field>
        <field name="parent_id" ref="rehab_discipline_menu_cat"/>
        <field name="action" ref="action_rehab_discipline_case"/>
        <field name="sequence">10</field>
    </record>

    <record id="menu_rehab_billing" model="ir.ui.menu">
        <field name="name">Generate Monthly Billing</field>
        <field name="parent_id" ref="rehab_financials_menu_cat"/>
        <field name="action" ref="action_rehab_billing_wizard"/>
        <field name="sequence">5</field>
    </record>

    <record id="menu_rehab_money_in" model="ir.ui.menu">
        <field name="name">Money IN (Invoices)</field>
        <field name="parent_id" ref="rehab_finance_dashboard_cat"/>
        <field name="action" ref="account.action_move_out_invoice_type"/>
        <field name="sequence">10</field>
    </record>

    <record id="menu_rehab_money_out" model="ir.ui.menu">
        <field name="name">Money OUT (Teacher Salaries)</field>
        <field name="parent_id" ref="rehab_finance_dashboard_cat"/>
        <field name="action" ref="account.action_move_in_invoice_type"/>
        <field name="sequence">20</field>
    </record>

    <record id="menu_rehab_payments" model="ir.ui.menu">
        <field name="name">Payments Received</field>
        <field name="parent_id" ref="rehab_finance_dashboard_cat"/>
        <field name="action" ref="account.action_account_payments"/>
        <field name="sequence">30</field>
    </record>

    <record id="menu_rehab_finance_reports_cat" model="ir.ui.menu">
        <field name="name">Finance Reports</field>
        <field name="parent_id" ref="rehab_finance_dashboard_cat"/>
        <field name="sequence">100</field>
    </record>

    <record id="menu_rehab_report_pl" model="ir.ui.menu">
        <field name="name">Profit &amp; Loss</field>
        <field name="parent_id" ref="menu_rehab_finance_reports_cat"/>
        <field name="action" ref="action_rehab_report_pl"/>
        <field name="sequence">10</field>
    </record>

    <record id="menu_rehab_report_bs" model="ir.ui.menu">
        <field name="name">Balance Sheet</field>
        <field name="parent_id" ref="menu_rehab_finance_reports_cat"/>
        <field name="action" ref="action_rehab_report_bs"/>
        <field name="sequence">20</field>
    </record>

    <record id="menu_rehab_report_tb" model="ir.ui.menu">
        <field name="name">Trial Balance</field>
        <field name="parent_id" ref="menu_rehab_finance_reports_cat"/>
        <field name="action" ref="action_rehab_report_tb"/>
        <field name="sequence">30</field>
    </record>

    <record id="menu_rehab_ledger" model="ir.ui.menu">
        <field name="name">Complete Ledger</field>
        <field name="parent_id" ref="menu_rehab_finance_reports_cat"/>
        <field name="action" ref="account.action_account_moves_all"/>
        <field name="sequence">40</field>
    </record>

    <record id="menu_rehab_room" model="ir.ui.menu">
        <field name="name">Rooms</field>
        <field name="parent_id" ref="rehab_dormitory_menu_cat"/>
        <field name="action" ref="action_rehab_room"/>
        <field name="sequence">10</field>
    </record>

    <record id="menu_rehab_teacher" model="ir.ui.menu">
        <field name="name">Teachers</field>
        <field name="parent_id" ref="rehab_dormitory_menu_cat"/>
        <field name="action" ref="action_rehab_teacher"/>
        <field name="sequence">20</field>
    </record>

    <record id="menu_rehab_class" model="ir.ui.menu">
        <field name="name">Classes</field>
        <field name="parent_id" ref="rehab_dormitory_menu_cat"/>
        <field name="action" ref="action_rehab_class"/>
        <field name="sequence">30</field>
    </record>

    <record id="menu_rehab_student_type" model="ir.ui.menu">
        <field name="name">Student Types</field>
        <field name="parent_id" ref="rehab_configuration_cat"/>
        <field name="action" ref="action_rehab_student_type"/>
        <field name="sequence">5</field>
    </record>

</odoo>
