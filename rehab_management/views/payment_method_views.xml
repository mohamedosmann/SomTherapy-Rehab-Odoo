<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="payment_method_view_form_rehab" model="ir.ui.view">
        <field name="name">payment.method.view.form.rehab</field>
        <field name="model">payment.method</field>
        <field name="inherit_id" ref="account.payment_method_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="code" placeholder="Unique Code (e.g. evc_plus)"/>
            </xpath>
        </field>
    </record>
</odoo>
