<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Room Views -->
    <record id="rehab_room_view_tree" model="ir.ui.view">
        <field name="name">rehab.room.list</field>
        <field name="model">rehab.room</field>
        <field name="arch" type="xml">
            <tree string="Rooms">
                <field name="name"/>
                <field name="capacity"/>
                <field name="type"/>
                <field name="is_archived"/>
            </tree>
        </field>
    </record>

    <record id="rehab_room_view_form" model="ir.ui.view">
        <field name="name">rehab.room.form</field>
        <field name="model">rehab.room</field>
        <field name="arch" type="xml">
            <form string="Room">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="capacity"/>
                        <field name="type"/>
                        <field name="is_archived"/>
                    </group>
                    <notebook>
                        <page name="students" string="Students">
                            <field name="student_ids" readonly="1">
                                <tree>
                                    <field name="student_id"/>
                                    <field name="name"/>
                                    <field name="status"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Teacher Views -->
    <record id="rehab_teacher_view_tree" model="ir.ui.view">
        <field name="name">rehab.teacher.list</field>
        <field name="model">rehab.teacher</field>
        <field name="arch" type="xml">
            <tree string="Teachers">
                <field name="name"/>
                <field name="role"/>
                <field name="subject"/>
                <field name="email"/>
            </tree>
        </field>
    </record>

    <record id="rehab_teacher_view_form" model="ir.ui.view">
        <field name="name">rehab.teacher.form</field>
        <field name="model">rehab.teacher</field>
        <field name="arch" type="xml">
            <form string="Teacher">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Teacher Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="role"/>
                            <field name="subject"/>
                            <field name="email"/>
                            <field name="phone"/>
                        </group>
                        <group>
                            <field name="salary"/>
                            <field name="hire_date"/>
                            <field name="is_archived"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="identity" string="Documents">
                            <group>
                                <field name="profile_image" widget="image" class="oe_avatar"/>
                                <field name="passport_image" widget="image"/>
                                <field name="cid_letter" widget="image"/>
                                <field name="contract_url" widget="url"/>
                                <field name="uni_certificates" widget="image"/>
                            </group>
                        </page>
                        <page name="classes" string="Classes">
                            <field name="class_ids" readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="schedule"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Class Views -->
    <record id="rehab_class_view_tree" model="ir.ui.view">
        <field name="name">rehab.class.list</field>
        <field name="model">rehab.class</field>
        <field name="arch" type="xml">
            <tree string="Classes">
                <field name="name"/>
                <field name="teacher_id"/>
                <field name="schedule"/>
            </tree>
        </field>
    </record>

    <record id="rehab_class_view_form" model="ir.ui.view">
        <field name="name">rehab.class.form</field>
        <field name="model">rehab.class</field>
        <field name="arch" type="xml">
            <form string="Class">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="teacher_id"/>
                        <field name="schedule"/>
                        <field name="is_archived"/>
                    </group>
                    <notebook>
                        <page name="students" string="Students">
                            <field name="student_ids">
                                <tree>
                                    <field name="student_id"/>
                                    <field name="name"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
