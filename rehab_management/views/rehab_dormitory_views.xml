<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Room Views -->
    <record id="rehab_room_view_tree" model="ir.ui.view">
        <field name="name">rehab.room.tree</field>
        <field name="model">rehab.room</field>
        <field name="arch" type="xml">
            <list string="Rooms">
                <field name="name"/>
                <field name="capacity"/>
                <field name="type"/>
                <field name="extra_charge"/>
                <field name="is_archived"/>
            </list>
        </field>
    </record>

    <record id="rehab_room_view_form" model="ir.ui.view">
        <field name="name">rehab.room.form</field>
        <field name="model">rehab.room</field>
        <field name="arch" type="xml">
            <form string="Room">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="capacity"/>
                        <field name="type"/>
                        <field name="extra_charge"/>
                        <field name="is_archived"/>
                    </group>
                    <notebook>
                        <page name="students" string="Students">
                            <field name="student_ids" readonly="1">
                                <list>
                                    <field name="student_id"/>
                                    <field name="name"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Class Views -->
    <record id="rehab_class_view_tree" model="ir.ui.view">
        <field name="name">rehab.class.tree</field>
        <field name="model">rehab.class</field>
        <field name="arch" type="xml">
            <list string="Classes">
                <field name="name"/>
                <field name="teacher_id"/>
                <field name="schedule"/>
            </list>
        </field>
    </record>

    <record id="rehab_class_view_form" model="ir.ui.view">
        <field name="name">rehab.class.form</field>
        <field name="model">rehab.class</field>
        <field name="arch" type="xml">
            <form string="Class">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="teacher_id"/>
                        <field name="schedule"/>
                        <field name="is_archived"/>
                    </group>
                    <notebook>
                        <page name="students" string="Students">
                            <field name="student_ids">
                                <list>
                                    <field name="student_id"/>
                                    <field name="name"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
