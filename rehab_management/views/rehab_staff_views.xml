<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_rehab_staff_tree" model="ir.ui.view">
        <field name="name">rehab.staff.tree</field>
        <field name="model">rehab.staff</field>
        <field name="arch" type="xml">
            <list string="Staff">
                <field name="staff_id"/>
                <field name="name"/>
                <field name="job_role"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_rehab_staff_form" model="ir.ui.view">
        <field name="name">rehab.staff.form</field>
        <field name="model">rehab.staff</field>
        <field name="arch" type="xml">
            <form string="Staff Member">
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="active,inactive"/>
                </header>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Staff Name"/>
                        </h1>
                        <h3>
                            <field name="job_role"/>
                        </h3>
                    </div>
                    <notebook>
                        <page name="info" string="Employment Info">
                            <group>
                                <group>
                                    <field name="staff_id"/>
                                    <field name="partner_id" readonly="1"/>
                                    <field name="phone"/>
                                    <field name="email"/>
                                </group>
                                <group>
                                    <field name="specialization" invisible="job_role != 'teacher'"/>
                                    <field name="department"/>
                                    <field name="salary_amount"/>
                                </group>
                            </group>
                        </page>
                        <page name="classes" string="Assigned Classes" invisible="job_role != 'teacher'">
                            <field name="class_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="schedule"/>
                                </list>
                            </field>
                        </page>
                        <page name="documents" string="Identity Documents">
                            <group>
                                <group string="Main Identity">
                                    <field name="passport_image" widget="image"/>
                                    <field name="cid_letter" widget="image"/>
                                </group>
                                <group string="Educational &amp; Legal">
                                    <field name="uni_certificates" widget="image"/>
                                    <field name="contract_url" widget="url"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
