<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rehab_student_view_tree" model="ir.ui.view">
        <field name="name">rehab.student.list</field>
        <field name="model">rehab.student</field>
        <field name="arch" type="xml">
            <list string="Students">
                <field name="student_id"/>
                <field name="name"/>
                <field name="phone"/>
                <field name="type"/>
                <field name="status"/>
                <field name="monthly_fee" sum="Total Fees"/>
                <field name="room_id"/>
                <field name="class_id"/>
            </list>
        </field>
    </record>

    <record id="rehab_student_view_form" model="ir.ui.view">
        <field name="name">rehab.student.form</field>
        <field name="model">rehab.student</field>
        <field name="arch" type="xml">
            <form string="Student">
                <header>
                    <button name="%(account.action_move_out_invoice_type)d" string="Invoices" type="action" class="oe_highlight" context="{'search_default_partner_id': partner_id, 'default_partner_id': partner_id, 'default_move_type': 'out_invoice'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Student Name"/>
                        </h1>
                        <h3>
                            <field name="student_id" placeholder="Student ID (e.g. STU-001)"/>
                        </h3>
                    </div>
                    <group>
                        <group name="personal_info" string="Personal Information">
                            <field name="partner_id" context="{'default_name': name, 'default_customer_rank': 1}"/>
                            <field name="phone"/>
                            <field name="type"/>
                            <field name="status"/>
                            <field name="department"/>
                        </group>
                        <group name="financial" string="Financial">
                            <field name="monthly_fee" widget="monetary"/>
                            <field name="last_billing_date"/>
                            <field name="prepaid_balance" widget="monetary"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="placement" string="Placement">
                            <group>
                                <field name="room_id"/>
                                <field name="class_id"/>
                            </group>
                        </page>
                        <page name="identity" string="Documents &amp; Identity">
                            <group>
                                <group>
                                    <field name="profile_image" widget="image" class="oe_avatar"/>
                                    <field name="passport_image" widget="image"/>
                                    <field name="cid_letter" widget="image"/>
                                </group>
                                <group>
                                    <field name="contract_url" widget="url"/>
                                    <field name="uni_certificates" widget="image"/>
                                </group>
                            </group>
                        </page>
                        <page name="kin" string="Kin of Next">
                            <group>
                                <group string="Kin 1">
                                    <field name="kin1_name"/>
                                    <field name="kin1_phone"/>
                                    <field name="kin1_image" widget="image"/>
                                </group>
                                <group string="Kin 2">
                                    <field name="kin2_name"/>
                                    <field name="kin2_phone"/>
                                    <field name="kin2_image" widget="image"/>
                                </group>
                            </group>
                        </page>
                        <page name="cases" string="Discipline Cases">
                            <field name="case_ids">
                                <list>
                                    <field name="date_reported"/>
                                    <field name="violation"/>
                                    <field name="priority"/>
                                    <field name="status"/>
                                    <field name="fine_amount" sum="Total Fines"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>
</odoo>
