<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rehab_student_view_list" model="ir.ui.view">
        <field name="name">rehab.student.list</field>
        <field name="model">rehab.student</field>
        <field name="arch" type="xml">
            <list string="Students">
                <field name="student_id"/>
                <field name="name"/>
                <field name="phone"/>
                <field name="type"/>
                <field name="status"/>
                <field name="monthly_fee" sum="Total Fees"/>
                <field name="room_id"/>
                <field name="class_id"/>
            </list>
        </field>
    </record>

    <record id="rehab_student_view_form" model="ir.ui.view">
        <field name="name">rehab.student.form</field>
        <field name="model">rehab.student</field>
        <field name="arch" type="xml">
            <form string="Student">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoices"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-file-text-o"
                            string="Invoices"/>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Student Name"/></h1>
                        <label for="student_id"/>
                        <h3><field name="student_id" placeholder="STU-001"/></h3>
                    </div>
                    <group>
                        <group string="Personal Information">
                            <field name="partner_id"/>
                            <field name="phone"/>
                            <field name="type"/>
                            <field name="status"/>
                            <field name="department"/>
                        </group>
                        <group string="Financial">
                            <field name="monthly_fee"/>
                            <field name="last_billing_date"/>
                            <field name="prepaid_balance"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Placement">
                            <group>
                                <field name="room_id"/>
                                <field name="class_id"/>
                            </group>
                        </page>
                        <page string="Documents">
                            <group>
                                <field name="profile_image" widget="image" class="oe_avatar"/>
                                <field name="passport_image" widget="image"/>
                                <field name="cid_letter" widget="image"/>
                                <field name="contract_url" widget="url"/>
                            </group>
                        </page>
                        <page string="Next of Kin">
                            <group>
                                <group string="Contact 1">
                                    <field name="kin1_name"/>
                                    <field name="kin1_phone"/>
                                    <field name="kin1_image" widget="image"/>
                                </group>
                                <group string="Contact 2">
                                    <field name="kin2_name"/>
                                    <field name="kin2_phone"/>
                                    <field name="kin2_image" widget="image"/>
                                </group>
                            </group>
                        </page>
                        <page string="Discipline Cases">
                            <field name="case_ids">
                                <list>
                                    <field name="date_reported"/>
                                    <field name="violation"/>
                                    <field name="priority"/>
                                    <field name="status"/>
                                    <field name="fine_amount" sum="Total Fines"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>
</odoo>
