<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rehab_student_view_tree" model="ir.ui.view">
        <field name="name">rehab.student.tree</field>
        <field name="model">rehab.student</field>
        <field name="arch" type="xml">
            <list string="Students">
                <field name="student_id"/>
                <field name="name"/>
                <field name="phone"/>
                <field name="type_id"/>
                <field name="status"/>
                <field name="monthly_fee" sum="Total Fees"/>
                <field name="room_id"/>
                <field name="class_id"/>
            </list>
        </field>
    </record>

    <record id="rehab_student_view_form" model="ir.ui.view">
        <field name="name">rehab.student.form</field>
        <field name="model">rehab.student</field>
        <field name="arch" type="xml">
            <form string="Student">
                <sheet>
                    <field name="currency_id" invisible="1"/>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoices"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-pencil-square-o">
                            <div class="o_form_field o_stat_info">
                                <span class="o_stat_value"><field name="total_invoiced" widget="monetary"/></span>
                                <span class="o_stat_text">Invoiced</span>
                            </div>
                        </button>
                        <button name="action_view_payments"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-money">
                            <div class="o_form_field o_stat_info">
                                <span class="o_stat_value"><field name="total_paid" widget="monetary"/></span>
                                <span class="o_stat_text">Paid</span>
                            </div>
                        </button>
                        <button name="action_register_advanced_payment"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-plus-circle"
                            string="Pay Advance"/>
                    </div>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Full Name"/></h1>
                        <h2 class="o_row">
                            <field name="student_id" readonly="1"/>
                        </h2>
                    </div>
                    <group>
                        <group string="Basic Details">
                            <field name="phone" placeholder="+252..."/>
                            <field name="type_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="status" widget="radio" options="{'horizontal': true}"/>
                        </group>
                        <group string="Billing &amp; Placement">
                            <field name="monthly_fee" decoration-bf="1"/>
                            <field name="room_id"/>
                            <field name="class_id"/>
                        </group>
                    </group>
                    <group string="Live Financial Status">
                        <group text-align="center">
                            <field name="total_due" widget="monetary" decoration-danger="total_due &gt; 0" string="Current Debt"/>
                            <field name="prepaid_balance" widget="monetary" decoration-success="prepaid_balance &gt; 0" string="Credit Balance"/>
                        </group>
                        <group>
                            <field name="last_billing_date" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Placement" name="placement">
                            <group>
                                <field name="room_id"/>
                                <field name="class_id"/>
                            </group>
                        </page>
                        <page string="Documents" name="documents">
                            <group>
                                <field name="profile_image" widget="image" class="oe_avatar"/>
                                <field name="passport_image" widget="image"/>
                                <field name="cid_letter" widget="image"/>
                                <field name="contract_url" widget="url"/>
                            </group>
                        </page>
                        <page string="Next of Kin" name="kin">
                            <group>
                                <group string="Contact 1">
                                    <field name="kin1_name"/>
                                    <field name="kin1_phone"/>
                                    <field name="kin1_image" widget="image"/>
                                </group>
                                <group string="Contact 2">
                                    <field name="kin2_name"/>
                                    <field name="kin2_phone"/>
                                    <field name="kin2_image" widget="image"/>
                                </group>
                            </group>
                        </page>
                        <page string="Discipline Cases" name="discipline">
                            <field name="case_ids">
                                <list>
                                    <field name="date_reported"/>
                                    <field name="violation"/>
                                    <field name="priority"/>
                                    <field name="status"/>
                                    <field name="fine_amount" sum="Total Fines"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="rehab_student_view_search" model="ir.ui.view">
        <field name="name">rehab.student.search</field>
        <field name="model">rehab.student</field>
        <field name="arch" type="xml">
            <search string="Students">
                <field name="name"/>
                <field name="student_id"/>
            </search>
        </field>
    </record>

    <record id="rehab_student_view_kanban" model="ir.ui.view">
        <field name="name">rehab.student.kanban</field>
        <field name="model">rehab.student</field>
        <field name="arch" type="xml">
            <kanban sample="1">
                <field name="name"/>
                <field name="student_id"/>
                <field name="type_id"/>
                <field name="status"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title"><field name="name"/></strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <field name="student_id"/>
                                <div><field name="type_id"/></div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="status" widget="label_selection" options="{'classes': {'Active': 'success', 'Inactive': 'warning'}}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <!-- Student Type Views -->
    <record id="rehab_student_type_view_list" model="ir.ui.view">
        <field name="name">rehab.student.type.list</field>
        <field name="model">rehab.student.type</field>
        <field name="arch" type="xml">
            <list string="Student Types" editable="bottom">
                <field name="name"/>
                <field name="default_monthly_fee"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="rehab_student_type_view_form" model="ir.ui.view">
        <field name="name">rehab.student.type.form</field>
        <field name="model">rehab.student.type</field>
        <field name="arch" type="xml">
            <form string="Student Type">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="default_monthly_fee"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
