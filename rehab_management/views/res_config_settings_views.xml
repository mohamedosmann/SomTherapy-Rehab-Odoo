<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.rehab</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="90"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Rehab Management" string="Rehab Management" name="rehab_management" groups="base.group_user">
                    
                    <block title="Accounting Integration" name="rehab_accounting_setting_container">
                        <setting id="rehab_billing_products" title="Billing Products" help="Set default products for rendering invoices safely.">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="rehab_fee_product_id" class="col-lg-4 o_light_label"/>
                                    <field name="rehab_fee_product_id" context="{'default_detailed_type': 'service'}"/>
                                </div>
                                <div class="row mt16">
                                    <label for="rehab_fine_product_id" class="col-lg-4 o_light_label"/>
                                    <field name="rehab_fine_product_id" context="{'default_detailed_type': 'service'}"/>
                                </div>
                            </div>
                        </setting>

                        <setting id="rehab_journals" title="Default Journals" help="Select which journals will be used automatically.">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="rehab_invoice_journal_id" class="col-lg-4 o_light_label"/>
                                    <field name="rehab_invoice_journal_id"/>
                                </div>
                            </div>
                        </setting>

                        <setting id="rehab_payroll" title="Payroll Configuration" help="Set accounts for staff salaries.">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="rehab_staff_salary_account_id" class="col-lg-4 o_light_label"/>
                                    <field name="rehab_staff_salary_account_id"/>
                                </div>
                                <div class="row mt16">
                                    <label for="rehab_staff_payable_account_id" class="col-lg-4 o_light_label"/>
                                    <field name="rehab_staff_payable_account_id"/>
                                </div>
                            </div>
                        </setting>
                    </block>

                </app>
            </xpath>
        </field>
    </record>

    <record id="rehab_config_settings_action" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module' : 'rehab_management'}</field>
    </record>
    
    <record id="menu_rehab_config_settings" model="ir.ui.menu">
        <field name="name">General Settings</field>
        <field name="parent_id" ref="rehab_configuration_cat"/>
        <field name="action" ref="rehab_config_settings_action"/>
        <field name="sequence">0</field>
    </record>
</odoo>
