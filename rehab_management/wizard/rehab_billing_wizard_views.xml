<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_rehab_billing_wizard_form" model="ir.ui.view">
        <field name="name">rehab.billing.wizard.form</field>
        <field name="model">rehab.billing.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Monthly Invoices">
                <group>
                    <field name="billing_date"/>
                </group>
                <notebook>
                    <page name="students" string="Selected Students">
                        <field name="student_ids">
                            <list>
                                <field name="student_id"/>
                                <field name="name"/>
                                <field name="type"/>
                                <field name="monthly_fee"/>
                            </list>
                        </field>
                    </page>
                </notebook>
                <footer>
                    <button name="action_generate_invoices" string="Generate Invoices" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_rehab_billing_wizard" model="ir.actions.act_window">
        <field name="name">Monthly Billing</field>
        <field name="res_model">rehab.billing.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
