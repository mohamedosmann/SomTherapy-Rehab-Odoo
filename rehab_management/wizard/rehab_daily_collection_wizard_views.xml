<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_rehab_daily_collection_wizard_form" model="ir.ui.view">
        <field name="name">rehab.daily.collection.wizard.form</field>
        <field name="model">rehab.daily.collection.wizard</field>
        <field name="arch" type="xml">
            <form string="Daily Cash Collection Report">
                <group>
                    <field name="date"/>
                    <field name="journal_ids" widget="many2many_tags" options="{'no_create': True}"/>
                </group>
                <footer>
                    <button name="action_generate_report" string="Print PDF Report" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_rehab_daily_collection_wizard" model="ir.actions.act_window">
        <field name="name">Daily Collection Report</field>
        <field name="res_model">rehab.daily.collection.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
