<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_rehab_staff_payment_wizard_form" model="ir.ui.view">
        <field name="name">rehab.staff.payment.wizard.form</field>
        <field name="model">rehab.staff.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Staff Salary Bills">
                <group>
                    <field name="date"/>
                </group>
                <notebook>
                    <page name="staff" string="Selected Staff Members">
                        <field name="staff_ids">
                            <list>
                                <field name="staff_id"/>
                                <field name="name"/>
                                <field name="job_role"/>
                                <field name="salary_amount" sum="Total Salaries"/>
                            </list>
                        </field>
                    </page>
                </notebook>
                <footer>
                    <button name="action_generate_bills" string="Generate Staff Bills" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_rehab_staff_payment_wizard" model="ir.actions.act_window">
        <field name="name">Staff Salary Distribution</field>
        <field name="res_model">rehab.staff.payment.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
